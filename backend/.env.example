# Server Configuration
NODE_ENV=production
PORT=10000

# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/mobafolio?retryWrites=true&w=majority

# JWT Secret (use a long random string)
JWT_SECRET=your_super_secret_key_change_this_to_something_random_and_long

# CORS Origin (your frontend Render URL)
CORS_ORIGIN=https://mobafolio-frontend.onrender.com